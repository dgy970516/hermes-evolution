# 飞书配置（使用 WebSocket 长连接，无需 ngrok）
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
# 飞书事件订阅方式需选择: "通过长连接接收事件"

# Hermes 自身 AI（用于意图识别/摘要/学习）
# DeepSeek 兼容 OpenAI 格式
HERMES_AI_PROVIDER=openai_compatible
HERMES_AI_MODEL=deepseek-v4-flash
HERMES_AI_API_KEY=sk-
HERMES_AI_BASE_URL=https://api.deepseek.com/v1

# 网络/SSL（国内网络遇到 SSL 错误时设为 none）
SSL_VERIFY=none

# Hermes 配置
HERMES_LOG_LEVEL=INFO
HERMES_WEBHOOK_PORT=9000
HERMES_DEFAULT_ENGINE=opencode
