# Hermes 配置模板 — 复制为 .env 并填入实际值

# ── AI 模型 ──
# 支持: openai | anthropic | openai_compatible（兼容 OpenAI 格式）
HERMES_AI_PROVIDER=openai_compatible
HERMES_AI_MODEL=deepseek-v4-flash
HERMES_AI_API_KEY=sk-xxx
# openai_compatible 时填写 API 地址
HERMES_AI_BASE_URL=https://api.deepseek.com/v1

# ── 飞书 Bot ──
# 使用 WebSocket 长连接，无需 ngrok
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_VERIFICATION_TOKEN=xxx
FEISHU_ENCRYPT_KEY=xxx

# ── 执行引擎 ──
OPENCODE_API_KEY=sk-xxx
ANTHROPIC_API_KEY=

# ── 网络 ──
# 国内网络遇 SSL 错误时设为 none
SSL_VERIFY=none

# ── Hermes ──
HERMES_LOG_LEVEL=INFO
HERMES_WEBHOOK_PORT=9000
HERMES_DEFAULT_ENGINE=opencode
